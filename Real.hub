    btn.Position = UDim2.new(1, -96, 0.5, -12)
    btn.BackgroundColor3 = Color3.fromRGB(20,20,20)
    btn.BackgroundTransparency = 0.05
    btn.Text = kb.key.Name
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 11
    btn.TextColor3 = Color3.fromRGB(255,255,255)
    btn.TextXAlignment = Enum.TextXAlignment.Center
    btn.Parent = row
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
    mkOutline(btn, 1)
    mkGlow(btn, false)
    btn.MouseButton1Click:Connect(function()
        if _kbListenConn then _kbListenConn:Disconnect(); _kbListenConn = nil end
        if _rebinding and _kbBtns[_rebinding] then
            local prev = _kbBtns[_rebinding]
            prev.Text = KEYBINDS[_rebinding].key.Name
            prev.BackgroundColor3 = Color3.fromRGB(20,20,20)
        end
        _rebinding = kbIdx
        _kbBtns[kbIdx] = btn
        btn.Text = "..."
        btn.BackgroundColor3 = Color3.fromRGB(50,50,0)
        _kbListenConn = UIS.InputBegan:Connect(function(input)
            local ut = input.UserInputType
            if ut == Enum.UserInputType.Keyboard or ut == Enum.UserInputType.Gamepad1 or ut == Enum.UserInputType.Gamepad2 or ut == Enum.UserInputType.Gamepad3 or ut == Enum.UserInputType.Gamepad4 then
                if input.KeyCode == Enum.KeyCode.Escape then
                    btn.Text = KEYBINDS[kbIdx].key.Name
                    btn.BackgroundColor3 = Color3.fromRGB(20,20,20)
                    _rebinding = nil
                    if _kbListenConn then _kbListenConn:Disconnect(); _kbListenConn = nil end
                    return
                end
                KEYBINDS[kbIdx].key = input.KeyCode
                btn.Text = input.KeyCode.Name
                btn.BackgroundColor3 = Color3.fromRGB(20,20,20)
                _rebinding = nil
                if _kbListenConn then _kbListenConn:Disconnect(); _kbListenConn = nil end
            end
        end)
    end)
    _kbBtns[kbIdx] = btn
end
for i = 1, #KEYBINDS do
    mkKBRow(kbC, i)
end
