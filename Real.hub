local _wpBillboards = {}
local _wpParts = {}
local WP_LABELS_LEFT = {"Start", "Pos 2", "Pos 3", "End"}
local WP_LABELS_RIGHT = {"Start", "Pos 2", "Pos 3", "End"}
function ClearWaypoints()
    for _, bb in ipairs(_wpBillboards) do pcall(function() bb:Destroy() end) end
    for _, p in ipairs(_wpParts) do pcall(function() p:Destroy() end) end
    _wpBillboards = {}; _wpParts = {}
end
function CreateWaypoints()
    ClearWaypoints()
    local function makeWP(coords, labels, color)
        for i, coord in ipairs(coords) do
            local part = Instance.new("Part")
            part.Name = "RealHub_WP"
            part.Size = Vector3.new(0.5, 0.5, 0.5)
            part.Position = Vector3.new(coord[1], coord[2] + 5, coord[3])
            part.Anchored = true; part.CanCollide = false; part.Transparency = 1
            part.Parent = workspace
            table.insert(_wpParts, part)
            local bb = Instance.new("BillboardGui")
            bb.Name = "RealHub_WPBB"
            bb.Adornee = part; bb.Size = UDim2.new(5, 0, 1.2, 0)
            bb.StudsOffset = Vector3.new(0, 2, 0)
            bb.AlwaysOnTop = true; bb.MaxDistance = 500
            bb.Parent = part
            local bg = Instance.new("Frame")
            bg.Size = UDim2.new(1, 0, 1, 0)
            bg.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
            bg.BackgroundTransparency = 0.3
            bg.Parent = bb
            Instance.new("UICorner", bg).CornerRadius = UDim.new(0, 6)
            local st = Instance.new("UIStroke")
            st.Thickness = 1; st.Color = color
            st.ApplyStrokeMode = Enum.ApplyStrokeMode.Border; st.Parent = bg
            local lbl = Instance.new("TextLabel")
            lbl.Size = UDim2.new(1, 0, 1, 0)
            lbl.BackgroundTransparency = 1
            lbl.Text = labels[i] or ("Pos " .. i)
            lbl.Font = Enum.Font.GothamBold; lbl.TextScaled = true
            lbl.TextColor3 = color
            lbl.TextStrokeTransparency = 0
            lbl.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
            lbl.Parent = bg
            table.insert(_wpBillboards, bb)
        end
    end
    makeWP(AUTO_LEFT_COORDS, WP_LABELS_LEFT, Color3.fromRGB(100, 150, 255))
    makeWP(AUTO_RIGHT_COORDS, WP_LABELS_RIGHT, Color3.fromRGB(255, 150, 100))
end
local _espGui = Instance.new("ScreenGui")
_espGui.Name = "RealHub_ESP"
_espGui.ResetOnSpawn = false
_espGui.DisplayOrder = 9998
_espGui.Parent = game:GetService("CoreGui")
local _espBoxes = {}
local _espTracers = {}
local _espHighlights = {}
local _espPlayerConns = {}
local function espRemovePlayer(p)
    if _espBoxes[p] then pcall(function() _espBoxes[p]:Destroy() end); _espBoxes[p] = nil end
    if _espTracers[p] then pcall(function() _espTracers[p]:Destroy() end); _espTracers[p] = nil end
    if _espHighlights[p] then pcall(function() _espHighlights[p]:Destroy() end); _espHighlights[p] = nil end
    if _espPlayerConns[p] then
        for _, c in ipairs(_espPlayerConns[p]) do pcall(function() c:Disconnect() end) end
        _espPlayerConns[p] = nil
    end
end
local function espAddPlayer(p)
    if p == LP then return end
    espRemovePlayer(p)
    _espPlayerConns[p] = {}
    local function setupChar(char)
        if not char then return end
        pcall(function() if _espHighlights[p] then _espHighlights[p]:Destroy() end end)
        _espHighlights[p] = nil
        pcall(function() if _espBoxes[p] then _espBoxes[p]:Destroy() end end)
        _espBoxes[p] = nil
        local hl = Instance.new("Highlight")
        hl.Name = "RealHub_ESP_HL"
        hl.Adornee = char
        hl.FillColor = Color3.fromRGB(255, 0, 0)
        hl.FillTransparency = 0.85
        hl.OutlineColor = Color3.fromRGB(255, 0, 0)
        hl.OutlineTransparency = 0
        hl.Parent = char
        hl.Enabled = ST.ESPHighlightOn
        _espHighlights[p] = hl
        local box = Instance.new("Frame")
        box.Name = "ESPBox_" .. p.Name
        box.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
        box.BackgroundTransparency = 0.9
        box.BorderSizePixel = 0
        box.ZIndex = 2
        box.Visible = ST.ESPBoxOn
        box.Parent = _espGui
        local bs = Instance.new("UIStroke")
        bs.Name = "RS"
        bs.Thickness = 1.5
        bs.Color = Color3.fromRGB(255, 50, 50)
        bs.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
        bs.Parent = box
        local bg = Instance.new("UIGradient")
        bg.Name = "RSG"
        bg.Color = ColorSequence.new{
            ColorSequenceKeypoint.new(0, Color3.fromRGB(0,0,0)),
            ColorSequenceKeypoint.new(0.2, Color3.fromRGB(50,0,0)),
            ColorSequenceKeypoint.new(0.5, Color3.fromRGB(255,50,50)),
            ColorSequenceKeypoint.new(0.8, Color3.fromRGB(50,0,0)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(0,0,0))
        }
        bg.Rotation = 0
        bg.Parent = bs
        table.insert(_outlineAnims, {s = bs, g = bg, th = 1.5, r = 0})
        _espBoxes[p] = box
        local tracer = Instance.new("Frame")
        tracer.Name = "Tracer_" .. p.Name
        tracer.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
        tracer.BackgroundTransparency = 0.3
        tracer.BorderSizePixel = 0
        tracer.ZIndex = 1
        tracer.Visible = ST.ESPTracerOn
        tracer.Parent = _espGui
        _espTracers[p] = tracer
    end
    if p.Character then setupChar(p.Character) end
    table.insert(_espPlayerConns[p], p.CharacterAdded:Connect(function(char)
        task.wait(0.5)
        espAddPlayer(p)
    end))
end
local _espTick = 0
local function updateESP()
    _espTick = _espTick + 1
    if _espTick % 2 ~= 0 then return end
    local needBox = ST.ESPBoxOn
    local needTracer = ST.ESPTracerOn
    if not needBox and not needTracer then
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LP then
                if _espBoxes[p] then _espBoxes[p].Visible = false end
                if _espTracers[p] then _espTracers[p].Visible = false end
            end
        end
        return
    end
    local localChar = LP.Character
    if not localChar then
        for _, p in ipairs(Players:GetPlayers()) do
            if _espBoxes[p] then _espBoxes[p].Visible = false end
            if _espTracers[p] then _espTracers[p].Visible = false end
        end
        return
    end
    local localHRP = localChar:FindFirstChild("HumanoidRootPart")
    if not localHRP then return end
    local fromSP = cam:WorldToScreenPoint(localHRP.Position)
    local fromPos = Vector2.new(fromSP.X, fromSP.Y)
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LP and p.Character then
            local hrp = p.Character:FindFirstChild("HumanoidRootPart")
            local head = p.Character:FindFirstChild("Head")
            local hum = p.Character:FindFirstChildOfClass("Humanoid")
            if not hrp or not hum or hum.Health <= 0 then
                if _espBoxes[p] then _espBoxes[p].Visible = false end
                if _espTracers[p] then _espTracers[p].Visible = false end
                continue
            end
            local box = _espBoxes[p]
            if box then
                local topP = cam:WorldToScreenPoint((head and head.Position + Vector3.new(0, 0.5, 0)) or (hrp.Position + Vector3.new(0, 5, 0)))
                local botP = cam:WorldToScreenPoint(hrp.Position - Vector3.new(0, 2.5, 0))
                if topP.Z > 0 and botP.Z > 0 then
                    local bH = math.abs(botP.Y - topP.Y)
                    local maxHalfW = hrp.Size.X / 2
                    for _, part in ipairs(p.Character:GetChildren()) do
                        if part:IsA("BasePart") and part.Size.X > 0.3 and part.Size.Z > 0.3 then
                            local hw = math.max(part.Size.X, part.Size.Z) / 2
                            if hw > maxHalfW then maxHalfW = hw end
                        end
                    end
                    maxHalfW = maxHalfW * 1.15
                    local rightVec = hrp.CFrame.RightVector
                    local leftSP = cam:WorldToScreenPoint(hrp.Position + rightVec * maxHalfW)
                    local rightSP = cam:WorldToScreenPoint(hrp.Position - rightVec * maxHalfW)
                    local bW
                    if leftSP.Z > 0 and rightSP.Z > 0 then
                        bW = math.abs(rightSP.X - leftSP.X)
                    else
                        bW = bH * 0.55
                    end
                    local cx = (topP.X + botP.X) / 2
                    box.Size = UDim2.new(0, bW, 0, bH)
                    box.Position = UDim2.new(0, cx - bW/2, 0, topP.Y)
                    box.Visible = needBox
                else
                    box.Visible = false
                end
            end
            local tracer = _espTracers[p]
            if tracer then
                local toSP, toVis = cam:WorldToScreenPoint(hrp.Position)
                if toSP.Z > 0 then
                    local toPos = Vector2.new(toSP.X, toSP.Y)
                    local dx = toPos.X - fromPos.X
                    local dy = toPos.Y - fromPos.Y
                    local dist = math.sqrt(dx * dx + dy * dy)
                    if dist < 2 then
                        tracer.Visible = false
                    else
                        tracer.Visible = needTracer
                        local midX = (fromPos.X + toPos.X) / 2
                        local midY = (fromPos.Y + toPos.Y) / 2
                        tracer.AnchorPoint = Vector2.new(0.5, 0.5)
                        tracer.Position = UDim2.new(0, midX, 0, midY)
                        tracer.Size = UDim2.new(0, dist, 0, 1.5)
                        tracer.Rotation = math.deg(math.atan2(dy, dx))
                        tracer.BackgroundTransparency = math.clamp(1 - (dist / 800), 0.2, 0.7)
                    end
                else
                    tracer.Visible = false
                end
            end
        end
    end
end
safeCall("ESP", function()
RunService.Heartbeat:Connect(updateESP)
function EnableESPBox()
    for _, p in ipairs(Players:GetPlayers()) do espAddPlayer(p) end
    for _, p in ipairs(Players:GetPlayers()) do
        if _espBoxes[p] then _espBoxes[p].Visible = true end
    end
end
function DisableESPBox()
    for _, p in ipairs(Players:GetPlayers()) do
        if _espBoxes[p] then _espBoxes[p].Visible = false end
    end
end
function EnableESPTracer()
    for _, p in ipairs(Players:GetPlayers()) do espAddPlayer(p) end
    for _, p in ipairs(Players:GetPlayers()) do
        if _espTracers[p] then _espTracers[p].Visible = true end
    end
end
function DisableESPTracer()
    for _, p in ipairs(Players:GetPlayers()) do
        if _espTracers[p] then _espTracers[p].Visible = false end
    end
end
function EnableESPHighlight()
    for _, p in ipairs(Players:GetPlayers()) do espAddPlayer(p) end
    for _, p in ipairs(Players:GetPlayers()) do
        if _espHighlights[p] then _espHighlights[p].Enabled = true end
    end
end
function DisableESPHighlight()
    for _, p in ipairs(Players:GetPlayers()) do
        if _espHighlights[p] then _espHighlights[p].Enabled = false end
    end
end
Players.PlayerAdded:Connect(function(p)
    task.wait(1)
    espAddPlayer(p)
end)
Players.PlayerRemoving:Connect(function(p)
    espRemovePlayer(p)
end)
end)
local speedBB = nil
local speedText = nil
local discordBBText = nil
local function createSpeedBillboard()
    if speedBB then pcall(function() speedBB:Destroy() end) end
    local char = LP.Character
    if not char then return end
    local head = char:FindFirstChild("Head") or char:FindFirstChild("HumanoidRootPart")
    if not head then return end
    speedBB = Instance.new("BillboardGui")
    speedBB.Name = "RealHub_SpeedBB"
    speedBB.Adornee = head
    speedBB.Size = UDim2.new(8, 0, 3, 0)
    speedBB.StudsOffset = Vector3.new(0, 3.5, 0)
    speedBB.AlwaysOnTop = true
    speedBB.MaxDistance = 100
    speedBB.Parent = char
    local bg = Instance.new("Frame")
    bg.Size = UDim2.new(1, 0, 1, 0)
    bg.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    bg.BackgroundTransparency = 0.4
    bg.Parent = speedBB
    Instance.new("UICorner", bg).CornerRadius = UDim.new(0, 10)
    local bgSt = Instance.new("UIStroke")
    bgSt.Thickness = 2; bgSt.Color = Color3.fromRGB(255,50,50)
    bgSt.ApplyStrokeMode = Enum.ApplyStrokeMode.Border; bgSt.Parent = bg
    speedText = Instance.new("TextLabel")
    speedText.Size = UDim2.new(1, 0, 0.5, 0)
    speedText.Position = UDim2.new(0, 0, 0, 0)
    speedText.BackgroundTransparency = 1
    speedText.Text = "Speed: 0.0"
    speedText.Font = Enum.Font.GothamBlack; speedText.TextScaled = true
    speedText.TextColor3 = Color3.fromRGB(255, 255, 255)
    speedText.TextStrokeTransparency = 0
    speedText.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    speedText.Parent = bg
    mkGlow(speedText, false)
    discordBBText = Instance.new("TextLabel")
    discordBBText.Size = UDim2.new(1, 0, 0.3, 0)
    discordBBText.Position = UDim2.new(0, 0, 0.5, 0)
    discordBBText.BackgroundTransparency = 1
    discordBBText.Text = DISCORD_LINK
    discordBBText.Font = Enum.Font.GothamBold; discordBBText.TextScaled = true
    discordBBText.TextColor3 = Color3.fromRGB(100, 255, 100)
    discordBBText.TextStrokeTransparency = 0
    discordBBText.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    discordBBText.Parent = bg
end
local _bbTick = 0
RunService.Heartbeat:Connect(function()
    _bbTick = _bbTick + 1
    if _bbTick % 3 ~= 0 then return end
    local char = LP.Character
    if not char then
        if speedBB then pcall(function() speedBB:Destroy() end); speedBB = nil; speedText = nil; discordBBText = nil end
        return
    end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local head = char:FindFirstChild("Head") or hrp
    if not head or not hrp then
        if speedBB then pcall(function() speedBB:Destroy() end); speedBB = nil; speedText = nil; discordBBText = nil end
        return
    end
    if not speedBB or not speedBB.Parent then createSpeedBillboard() end
    if speedBB and speedBB.Parent and speedText then
        if speedBB.Adornee ~= head then speedBB.Adornee = head end
        local vel = hrp.Velocity or Vector3.zero
        local horizSpeed = Vector3.new(vel.X, 0, vel.Z).Magnitude
        speedText.Text = string.format("Speed: %.1f", horizSpeed)
        local camPos = cam.CFrame.Position
        local dist = (head.Position - camPos).Magnitude
        local scale = math.clamp(1.2 - (dist / 120), 0.2, 1.2)
        speedBB.Size = UDim2.new(8 * scale, 0, 3 * scale, 0)
    end
end)
task.delay(2, createSpeedBillboard)
LP.CharacterAdded:Connect(function(char)
    task.wait(1)
    if speedBB then pcall(function() speedBB:Destroy() end); speedBB = nil; speedText = nil; discordBBText = nil end
    createSpeedBillboard()
end)
local function AimbotCore(dt)
    if not ST.isAimbotActive then return end
    if iS() then ToggleAimbot(false); return end
    local char = LP.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    local root = char and char:FindFirstChild("HumanoidRootPart")
    if not root or not hum then return end
    pcall(function() CleanLocks(root) end)
    if not _aV or not _aV.Parent then
        pcall(function()
            if _aV and _aV.Parent then _aV:Destroy() end
            if _aA and _aA.Parent then _aA:Destroy() end
        end)
        local at = Instance.new("Attachment"); at.Name = "_UA_Att"; at.Parent = root
        local av = Instance.new("AngularVelocity"); av.Name = "_UA_AngV"
        av.Attachment0 = at; av.RelativeTo = Enum.ActuatorRelativeTo.World
        av.MaxTorque = CFG.AIM.MAX_TORQUE; av.AngularVelocity = Vector3.zero; av.Parent = root
        _aA = at; _aV = av
    end
    if not _bE then
        _bE = true
        if not char:FindFirstChildOfClass("Tool") then
            local bp = LP:FindFirstChildOfClass("Backpack")
            local bat = bp and bp:FindFirstChild("Bat")
            if bat then pcall(function() hum:EquipTool(bat) end) end
        end
    end
    local now = tick()
    local targetValid = _t and _t.Parent and _t.Parent:FindFirstChildOfClass("Humanoid") and _t.Parent:FindFirstChildOfClass("Humanoid").Health > 0
    if not (now - _ts <= 0.05 and targetValid) then
        _ts = now
        local cl, md = nil, math.huge
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LP and p.Character then
                local tr = p.Character:FindFirstChild("HumanoidRootPart")
                local h = p.Character:FindFirstChildOfClass("Humanoid")
                if tr and h and h.Health > 0 then
                    local d = (tr.Position - root.Position).Magnitude
                    if d < md then md = d; cl = tr end
                end
            end
        end
        if cl ~= _t then
            _vS = Vector3.zero; _smoothVel = Vector3.zero; _jH = {}; _iJD = false; _tDD = false; _pY = 0
        end
        _t = cl
    end
    if not _t then
        hum.AutoRotate = true
        if _aV then pcall(function() _aV.AngularVelocity = Vector3.zero end) end
        return
    end
    table.insert(_jH, (_t.Velocity and _t.Velocity.Y) or 0)
    if #_jH > CFG.AIM.MAX_JH then table.remove(_jH, 1) end
    local velY, posY = (_t.Velocity and _t.Velocity.Y) or 0, _t.Position.Y
    if posY > _pY then _pY = posY end
    local mode = "normal"
    local us = 0
    for i = 2, #_jH do
        if _jH[i] > CFG.AIM.JUMP_DET and _jH[i-1] < CFG.AIM.JUMP_DET * 0.3 then us = us + 1 end
    end
    if us >= CFG.AIM.JUMP_TRIG and not _iJD then _iJD = true; _pY = posY; _tDD = false end
    if _iJD and velY < CFG.AIM.TP_VEL then _tDD = true; mode = "tp_down"
    elseif _iJD and velY < -20 and (posY < _pY - 5) then mode = "falling"
    elseif _iJD and math.abs(velY) < 5 and posY < _lTY + 2 then
        _nMT = (_nMT or 0) + 1
        if _nMT > 8 then _iJD = false; _tDD = false; _pY = 0; _nMT = 0; _jH = {}; mode = "normal" end
    else _nMT = 0 end
    _lTY = posY
    if _iJD and mode == "normal" then mode = _tDD and "tp_down" or "infinite_jump" end
    local pos, vel = _t.Position, (_t.Velocity or Vector3.zero)
    local dd = (vel - (_vS or Vector3.zero)).Magnitude
    if dd < 250 then _vS = (_vS or Vector3.zero) * 0.78 + vel * 0.22 end
    local sv, ss = _vS or Vector3.zero, (_vS and _vS.Magnitude) or 0
    if ss > 75 then sv = sv.Unit * 75; ss = 75 end
    local targetSpeed = CFG.SPEED_NORMAL
    local speedFactor = math.clamp(ss / 50, 0, 1)
    local aimDist = 3 + speedFactor * 2
    local isE = false
    local pt = 0
    if mode == "infinite_jump" then
        local vm = math.clamp(sv.Y / 100, -0.3, 0.5)
        pt = CFG.AIM.JUMP_PREDICT + vm
        pos = pos + Vector3.new(sv.X * pt * 0.5, 0, sv.Z * pt * 0.5)
    elseif mode == "tp_down" then
        local lx, lz = pos.X + sv.X * CFG.AIM.TP_DOWN_PREDICT, pos.Z + sv.Z * CFG.AIM.TP_DOWN_PREDICT
        TP_RP.FilterDescendantsInstances = {LP.Character}
        local rr = workspace:Raycast(Vector3.new(lx, pos.Y, lz), Vector3.new(0, -200, 0), TP_RP)
        pos = Vector3.new(lx, rr and rr.Position.Y or pos.Y, lz)
        isE = true
    elseif mode == "falling" then
        pt = CFG.AIM.PREDICT * 0.8
        pos = pos + Vector3.new(sv.X * pt, 0, sv.Z * pt)
    else
        pt = math.clamp(ss / 130, 0.02, 0.12) * CFG.AIM.PREDICT
        pos = pos + (Vector3.new(sv.X, 0, sv.Z) * pt) + _t.CFrame.LookVector * 0.3
    end
    do
        local targetLook = _t.CFrame.LookVector
        pos = _t.Position + (targetLook * aimDist)
        aimDist = CFG.AIM.DIST
    end
    local look = pos - root.Position
    local fl = Vector3.new(look.X, 0, look.Z)
    hum.AutoRotate = false
    if look.Magnitude > 0.01 and fl.Magnitude > 0.01 then
        local tY = math.deg(math.atan2(-fl.X, -fl.Z))
        tY = tY + 180
        local yD = (tY - root.Orientation.Y + 180) % 360 - 180
        local tP = math.deg(math.atan2(look.Y, fl.Magnitude))
        local pD = (tP - root.Orientation.X + 180) % 360 - 180
        local yR = math.clamp(math.rad(yD) * CFG.AIM.TURN_SPEED, -CFG.AIM.MAX_TURN_RATE, CFG.AIM.MAX_TURN_RATE)
        local pR = math.clamp(math.rad(pD) * CFG.AIM.TURN_SPEED, -CFG.AIM.MAX_TURN_RATE, CFG.AIM.MAX_TURN_RATE)
        local yRd = math.rad(root.Orientation.Y)
        _aV.AngularVelocity = Vector3.new(0, yR, 0) + (Vector3.new(math.cos(yRd), 0, -math.sin(yRd)) * pR)
    else
        _aV.AngularVelocity = Vector3.zero
    end
    local tHV = Vector3.new((_t.Velocity and _t.Velocity.X) or 0, 0, (_t.Velocity and _t.Velocity.Z) or 0)
    local ms = tHV.Magnitude
    local pd
    if ms > 5 then pd = tHV.Unit
    else
        pd = Vector3.new(_t.CFrame.LookVector.X, 0, _t.CFrame.LookVector.Z)
        if pd.Magnitude > 0.01 then pd = pd.Unit else pd = Vector3.new(0, 0, -1) end
    end
    local sp = pos + (pd * aimDist)
    local md2 = sp - root.Position
    local hd = Vector3.new(md2.X, 0, md2.Z)
    local hv = hd.Magnitude > 0.1 and hd.Unit * targetSpeed or Vector3.zero
    local vv
    if isE then vv = Vector3.new(0, math.sign(md2.Y) * CFG.AIM.VERT_SPEED * 1.3, 0)
    elseif math.abs(md2.Y) > 3 then vv = Vector3.new(0, math.sign(md2.Y) * CFG.AIM.VERT_SPEED, 0)
    else vv = Vector3.new(0, -2, 0) end
    _iV = (_iV or Vector3.zero):Lerp(hv + vv, 1 - math.exp(-18 * (dt or 0)))
    _smoothVel = (_smoothVel or Vector3.zero):Lerp(_iV or Vector3.zero, 1 - math.exp(-25 * (dt or 0)))
    root.Velocity = _smoothVel or Vector3.zero
    if CFG.AIM.autoSwing and not _sCD then
        local bat = char:FindFirstChild("Bat")
        if bat and bat:IsA("Tool") then
            _sCD = true
            pcall(function()
                bat:Activate()
                local ev = bat:FindFirstChildWhichIsA("RemoteEvent")
                if ev then ev:FireServer() end
            end)
            task.delay(CFG.AIM.SWING_CD, function() _sCD = false end)
        end
    end
end
safeCall("AimbotConn", function()
RunService.Heartbeat:Connect(function(dt)
    if ST.isAimbotActive then AimbotCore(dt) end
end)
local _aimCleanTick = 0
RunService.RenderStepped:Connect(function()
    local r = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
    if r and ST.isAimbotActive then
        local v = r.Velocity or Vector3.zero
        if math.abs(v.X) > 250 or math.abs(v.Z) > 250 then r.Velocity = _smoothVel or Vector3.zero end
        _aimCleanTick = (_aimCleanTick or 0) + 1
        if _aimCleanTick % 15 == 0 then pcall(function() CleanLocks(r) end) end
    end
end)
LP.CharacterAdded:Connect(function(char)
    task.wait(0.5)
    _bE = false; _sCD = false
    _vS = Vector3.zero; _iV = Vector3.zero; _smoothVel = Vector3.zero
    _jH = {}; _iJD = false; _tDD = false
    _curFOV = 70; _lTY = 0; _pY = 0; _nMT = 0; _ts = 0; _t = nil
    if speedBB then pcall(function() speedBB:Destroy() end); speedBB = nil; speedText = nil; discordBBText = nil end
    StopSpeed(); StartSpeed()
    if ST.isAimbotActive then
        local hrp = char:WaitForChild("HumanoidRootPart", 5)
        if hrp then
            pcall(function() CleanLocks(hrp) end)
            pcall(function()
                if _aV and _aV.Parent then _aV:Destroy() end
                if _aA and _aA.Parent then _aA:Destroy() end
            end)
            local at = Instance.new("Attachment"); at.Name = "_UA_Att"; at.Parent = hrp
            local av = Instance.new("AngularVelocity"); av.Name = "_UA_AngV"
            av.Attachment0 = at; av.RelativeTo = Enum.ActuatorRelativeTo.World
            av.MaxTorque = CFG.AIM.MAX_TORQUE; av.AngularVelocity = Vector3.zero; av.Parent = hrp
            _aA = at; _aV = av
        end
    end
    task.delay(1, createSpeedBillboard)
end)
end)
local isGrab = false
local _grabHL = nil
local function clH()
    if _grabHL and _grabHL.Parent then _grabHL:Destroy() end
    _grabHL = nil
end
local function addH(m)
    clH()
    if not m or not m:IsA("Model") then return end
    local h = Instance.new("Highlight")
    h.Name = "RealHub_GrabTarget"
    h.Adornee = m
    h.FillColor = Color3.fromRGB(100,0,0)
    h.FillTransparency = 0.75
    h.OutlineColor = Color3.fromRGB(255,0,0)
    h.OutlineTransparency = 0
    h.Parent = m
    _grabHL = h
end
local function isMP(pn)
    local pl = workspace:FindFirstChild("Plots")
    if not pl then return false end
    local p = pl:FindFirstChild(pn)
    if not p then return false end
    local s = p:FindFirstChild("PlotSign")
    if s then
        local y = s:FindFirstChild("YourBase")
        if y and y:IsA("BillboardGui") then return y.Enabled == true end
    end
    return false
end
local _plotsRef, _plotsT = nil, 0
local function FNP()
    local h = gH()
    if not h then return nil end
    local now = tick()
    if not _plotsRef or now - _plotsT > 2 then
        _plotsRef = workspace:FindFirstChild("Plots")
        _plotsT = now
    end
    if not _plotsRef then return nil end
    local rn = CFG.STEAL_RANGE
    local np, npd, nm = nil, math.huge, nil
    for _, p2 in ipairs(_plotsRef:GetChildren()) do
        if p2:IsA("Model") and not isMP(p2.Name) then
            for _, c in ipairs(p2:GetDescendants()) do
                if c:IsA("BasePart") and c.Name ~= "HumanoidRootPart" then
                    local d = (c.Position - h.Position).Magnitude
                    if d < npd and d < rn then
                        npd = d
                        np = c
                        nm = p2
                    end
                end
            end
        end
    end
    return np, nm
end
local _grabConn = nil
local _grabActive = false
local function StartGrab()
    if _grabActive then return end
    _grabActive = true
    if _grabConn then _grabConn:Disconnect() end
    _grabConn = RunService.Heartbeat:Connect(function()
        if not _grabActive then return end
        local h = gH()
        if not h then return end
        local target, model = FNP()
        if target then
            addH(model)
            local dir = (target.Position - h.Position)
            local dist = dir.Magnitude
            if dist > 5 then
                local speed = (iS() and gSS()) or gNS() or 0
                speed = speed or 0
                h.Velocity = (dir.Unit and dir.Unit * speed) or Vector3.zero
            else
                h.Velocity = Vector3.new(0, (h.Velocity and h.Velocity.Y) or 0, 0)
            end
        else
            clH()
        end
    end)
end
local function StopGrab()
    _grabActive = false
    if _grabConn then _grabConn:Disconnect(); _grabConn = nil end
    clH()
end
local grabToggle = false
