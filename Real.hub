local _RH_ERRORS = 0
local _RH_ERRMAX = 100
local function _RH_WARN(msg)
    _RH_ERRORS = (_RH_ERRORS or 0) + 1
    if (_RH_ERRORS or 0) <= (_RH_ERRMAX or 100) then
        pcall(function() warn("[RealHub] " .. tostring(msg)) end)
    end
end
local function safeCall(name, fn)
    local ok, err = pcall(fn)
    if not ok then _RH_WARN(name .. ": " .. tostring(err)) end
end

