end
local activeTab = 1
local function switchTab(idx)
    activeTab = idx
    for i = 1, tabCount do
        tabContents[i].Visible = (i == idx)
        mkGlow(tabBtns[i], i == idx)
    end
    tabInd.Position = UDim2.new((1/tabCount) * (idx - 1), 0, 1, -1)
end
for i = 1, tabCount do
    tabBtns[i].MouseButton1Click:Connect(function() switchTab(i) end)
end
local function mkRow(parent, text, defaultVal, cb, minVal, maxVal)
    minVal = minVal or 0
    maxVal = maxVal or 9999
    local row = Instance.new("Frame")
    row.Size = UDim2.new(1, 0, 0, 32)
    row.BackgroundTransparency = 1
    row.Parent = parent
    local lb = Instance.new("TextLabel")
    lb.Size = UDim2.new(0, 130, 1, 0)
    lb.Position = UDim2.new(0, 4, 0, 0)
    lb.BackgroundTransparency = 1
    lb.Text = text
    lb.Font = Enum.Font.GothamBlack
    lb.TextSize = 11
    lb.TextXAlignment = Enum.TextXAlignment.Left
    lb.TextColor3 = Color3.fromRGB(255,255,255)
    lb.Parent = row
    mkGlow(lb)
    local tb = Instance.new("TextBox")
    tb.Size = UDim2.new(0, 90, 0, 26)
    tb.Position = UDim2.new(1, -96, 0.5, -13)
    tb.BackgroundColor3 = Color3.fromRGB(20,20,20)
    tb.BackgroundTransparency = 0.05
    tb.Text = tostring(defaultVal)
    tb.Font = Enum.Font.GothamBold
    tb.TextSize = 12
    tb.TextColor3 = Color3.fromRGB(255,255,255)
    tb.TextXAlignment = Enum.TextXAlignment.Center
    tb.ClearTextOnFocus = false
    tb.Parent = row
    Instance.new("UICorner", tb).CornerRadius = UDim.new(0, 6)
    mkOutline(tb, 1)
    mkGlow(tb, false)
    tb.FocusLost:Connect(function(ep)
        if ep then return end
        local clean = tb.Text:gsub("[^0-9.-]", "")
        local n = tonumber(clean)
        if n then
            n = math.clamp(n, minVal, maxVal)
            cb(n); tb.Text = tostring(n)
        else
            tb.Text = tostring(defaultVal)
        end
    end)
    tb:GetPropertyChangedSignal("Text"):Connect(function()
        local clean = tb.Text:gsub("[^0-9.-]", "")
        local n = tonumber(clean)
        if n then
            n = math.clamp(n, minVal, maxVal)
            cb(n)
        end
    end)
    return tb
end
local function mkToggle(parent, text, default, cb)
    local row = Instance.new("Frame")
    row.Size = UDim2.new(1, 0, 0, 32)
    row.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    row.BackgroundTransparency = 0.05
    row.Parent = parent
    Instance.new("UICorner", row).CornerRadius = UDim.new(0, 6)
    mkOutline(row, 1)
    local lb = Instance.new("TextLabel")
    lb.Size = UDim2.new(0, 180, 1, 0)
    lb.Position = UDim2.new(0, 8, 0, 0)
    lb.BackgroundTransparency = 1
    lb.Text = text
    lb.Font = Enum.Font.GothamBlack
    lb.TextSize = 11
    lb.TextXAlignment = Enum.TextXAlignment.Left
    lb.TextColor3 = Color3.fromRGB(255,255,255)
    lb.Parent = row
    mkGlow(lb)
    local state = default
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, 60, 0, 22)
    btn.Position = UDim2.new(1, -68, 0.5, -11)
    btn.BackgroundColor3 = state and Color3.fromRGB(10, 40, 10) or Color3.fromRGB(40, 10, 10)
    btn.Text = state and "ON" or "OFF"
    btn.TextColor3 = state and Color3.fromRGB(80, 255, 80) or Color3.fromRGB(255, 80, 80)
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 11
    btn.Parent = row
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)
    btn.MouseButton1Click:Connect(function()
        state = not state
        btn.Text = state and "ON" or "OFF"
        btn.BackgroundColor3 = state and Color3.fromRGB(10, 40, 10) or Color3.fromRGB(40, 10, 10)
        btn.TextColor3 = state and Color3.fromRGB(80, 255, 80) or Color3.fromRGB(255, 80, 80)
        cb(state)
    end)
    return btn
end
