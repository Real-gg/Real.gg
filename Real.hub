local AUDIO_CACHE_FOLDER = "RealHub_AudioCache"
local function EnsureAudioFolder()
    pcall(function()
        if isfolder and makefolder then
            if not isfolder(AUDIO_CACHE_FOLDER) then makefolder(AUDIO_CACHE_FOLDER) end
        elseif makefolder and not isfolder then
            makefolder(AUDIO_CACHE_FOLDER)
        end
    end)
end
safeCall("AudioFolder", EnsureAudioFolder)
local function PlayAudioFromURL(url, soundName, volume, looped)
    if not url or type(url) ~= "string" or #url < 5 then return nil end
    soundName = soundName or "RealHub_Audio"
    volume = (type(volume) == "number") and volume or 0.5
    looped = looped or false
    local sound
    local okCreate = pcall(function()
        sound = Instance.new("Sound")
        sound.Name = soundName
        sound.Volume = volume
        sound.Looped = looped
        sound.PlaybackSpeed = 1.0
    end)
    if not okCreate or not sound then return nil end
    if getcustomasset and writefile and isfile then
        local fileName = AUDIO_CACHE_FOLDER .. "/" .. soundName .. ".mp3"
        pcall(function()
            if isfolder and makefolder and not isfolder(AUDIO_CACHE_FOLDER) then
                makefolder(AUDIO_CACHE_FOLDER)
            end
        end)
        local fileExists = false
        pcall(function() fileExists = isfile(fileName) end)
        if not fileExists then
            pcall(function()
                local audioData = game:GetService("HttpService"):GetAsync(url)
                writefile(fileName, audioData)
            end)
        end
        pcall(function() fileExists = isfile(fileName) end)
        if fileExists then
            pcall(function() sound.SoundId = getcustomasset(fileName) end)
            if sound.SoundId == "" or not sound.SoundId then
                pcall(function() sound.SoundId = url end)
            end
            sound.Parent = workspace
            pcall(function() sound:Play() end)
            return sound
        end
    end
    pcall(function() sound.SoundId = url end)
    sound.Parent = workspace
    pcall(function() sound:Play() end)
    return sound
end
local function StopPreviewSound()
    if _previewSound and _previewSound.Parent then
        pcall(function() _previewSound:Stop() end)
        pcall(function() _previewSound:Destroy() end)
    end
    _previewSound = nil
end
local function PlayPreviewTrack(idx)
    StopPreviewSound()
    if not INTRO_TRACKS[idx] then return end
    task.spawn(function()
        _previewSound = PlayAudioFromURL(INTRO_TRACKS[idx], "RealHub_Preview_" .. idx, 0.5, false)
        if _previewSound then
            task.delay(15, function()
                if _previewSound and _previewSound.Parent then
                    pcall(function() _previewSound:Stop() end)
                    pcall(function() _previewSound:Destroy() end)
                    _previewSound = nil
                end
            end)
        end
    end)
end
local function DetectDevice()
    if UIS.TouchEnabled and not UIS.KeyboardEnabled then
        CFG.IS_MOBILE = true
        CFG.UI_SCALE = 0.7
    else
        CFG.IS_MOBILE = false
        CFG.UI_SCALE = 1.0
    end
end
