local function GetCoord(c) return c[1], c[2], c[3] end
local _moveKeys = {W=false,A=false,S=false,D=false,Up=false,Down=false,Left=false,Right=false}
local function getKeyMoveDir()
    local x, z = 0, 0
    if _moveKeys.W then z = z - 1 end
    if _moveKeys.S then z = z + 1 end
    if _moveKeys.A then x = x - 1 end
    if _moveKeys.D then x = x + 1 end
    local raw = Vector3.new(x, 0, z)
    if raw.Magnitude < 0.01 then
        if _moveKeys.Up then z = z - 1 end
        if _moveKeys.Down then z = z + 1 end
        if _moveKeys.Left then x = x - 1 end
        if _moveKeys.Right then x = x + 1 end
        raw = Vector3.new(x, 0, z)
    end
    if raw.Magnitude < 0.01 then return Vector3.zero end
    local camCF = workspace.CurrentCamera.CFrame
    local wd = camCF.RightVector * raw.X + camCF.LookVector * (-raw.Z)
    wd = Vector3.new(wd.X, 0, wd.Z)
    return wd.Magnitude > 0.01 and wd.Unit or Vector3.zero
end
local function DoDrop()
    if ST.DropActive then ST.DropActive = false; return end
    ST.DropActive = true
    local hrp = gH()
    if not hrp then ST.DropActive = false; return end
    local originalVel = hrp.Velocity or Vector3.zero
    table.insert(ST.DropConns, RunService.Stepped:Connect(function()
        if not ST.DropActive then return end
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LP and p.Character then
                for _, a in ipairs(p.Character:GetChildren()) do
                    if a:IsA("BasePart") then a.CanCollide = false end
                end
            end
        end
    end))
    task.spawn(function()
        local startTime = tick()
        while ST.DropActive and (tick() - startTime < 0.4) do
            RunService.Heartbeat:Wait()
            hrp = gH()
            if hrp then
                originalVel = hrp.Velocity
                local dV = originalVel * 500 + Vector3.new(0, 2000, 0)
                if dV.Magnitude > 10000 then dV = dV.Unit * 10000 end
                hrp.Velocity = dV
                RunService.RenderStepped:Wait()
                if hrp.Parent then hrp.Velocity = originalVel end
                RunService.Stepped:Wait()
                if hrp.Parent then hrp.Velocity = originalVel + Vector3.new(0, 0.1, 0) end
            end
        end
        ST.DropActive = false
        for _, c in ipairs(ST.DropConns) do
            pcall(function()
                if typeof(c) == "RBXScriptConnection" then c:Disconnect() end
            end)
        end
        ST.DropConns = {}
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LP and p.Character then
                for _, a in ipairs(p.Character:GetChildren()) do
                    if a:IsA("BasePart") then a.CanCollide = true end
                end
            end
        end
    end)
end
local function DoTPDown()
    pcall(function()
        local c = LP.Character
        local h = gH()
        if h and c and c.Parent then
            local origin = h.CFrame.Position
            local params = RaycastParams.new()
            params.FilterDescendantsInstances = {c}
            params.FilterType = Enum.RaycastFilterType.Exclude
            params.RespectCanCollide = true
            local result = workspace:Raycast(origin, Vector3.new(0, -1000, 0), params)
            if not result then
                result = workspace:Raycast(origin + c:GetPivot().LookVector * 3, Vector3.new(0, -1000, 0), params)
            end
            local targetY = -50
            if result then targetY = result.Position.Y + 3 end
            local rot = h.CFrame.Rotation
            local l1 = h.Velocity
            c:PivotTo(CFrame.new(h.Position.X, targetY, h.Position.Z) * rot)
            h.Velocity = l1
        end
    end)
end
local function ToggleAimbot(forceState)
    if forceState == false or (forceState ~= true and ST.isAimbotActive) then
        ST.isAimbotActive = false
        _t = nil; _bE = false
        if abF then abF.BackgroundColor3 = Color3.fromRGB(12,12,12) end
        if abBtn and mkGlow then mkGlow(abBtn, false) end
        local r = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
        local h = r and r.Parent and r.Parent:FindFirstChildOfClass("Humanoid")
        if r then r.Velocity = (r.Velocity or Vector3.zero) * 0.3 end
        pcall(function() CleanLocks(r) end)
        if h then h.AutoRotate = true end
        pcall(function() if _aV and _aV.Parent then _aV:Destroy() end end)
        pcall(function() if _aA and _aA.Parent then _aA:Destroy() end end)
        _aV = nil; _aA = nil
    elseif forceState == true or (forceState == nil and not ST.isAimbotActive) then
        ST.isAimbotActive = true; _bE = false
        if abF then abF.BackgroundColor3 = Color3.fromRGB(0,30,0) end
        if abBtn and mkGlow then mkGlow(abBtn, true) end
        _vS = Vector3.zero; _iV = Vector3.zero; _smoothVel = Vector3.zero
        _jH = {}; _iJD = false; _tDD = false
        local r = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
        if r then
            pcall(function() CleanLocks(r) end)
            pcall(function()
                if _aV and _aV.Parent then _aV:Destroy() end
                if _aA and _aA.Parent then _aA:Destroy() end
            end)
            local at = Instance.new("Attachment"); at.Name = "_UA_Att"; at.Parent = r
            local av = Instance.new("AngularVelocity"); av.Name = "_UA_AngV"
            av.Attachment0 = at; av.RelativeTo = Enum.ActuatorRelativeTo.World
            av.MaxTorque = CFG.AIM.MAX_TORQUE; av.AngularVelocity = Vector3.zero; av.Parent = r
            _aA = at; _aV = av
        end
    end
end
local function processKeybinds(input, isDown)
    if _rebinding or _sliderDrag then return false end
    for _, kb in ipairs(KEYBINDS) do
        if input.KeyCode == kb.key then
            if kb.type == "toggle" and isDown then
                if kb.name == "AimBot" then ToggleAimbot() end
            elseif kb.type == "click" and isDown then
                if kb.name == "Drop" then
                    DoDrop()
                    if dbF then dbF.BackgroundColor3 = Color3.fromRGB(0,30,0) end
                    task.delay(0.15, function() if dbF then dbF.BackgroundColor3 = Color3.fromRGB(12,12,12) end end)
                elseif kb.name == "Tp Down" then
                    DoTPDown()
                    if tdF then tdF.BackgroundColor3 = Color3.fromRGB(0,30,0) end
                    task.delay(0.15, function() if tdF then tdF.BackgroundColor3 = Color3.fromRGB(12,12,12) end end)
                elseif kb.name == "Auto Left" then
                    if ST.AutoLeftOn then StopAutoMove() else StartAutoMove("AUTO_LEFT") end
                elseif kb.name == "Auto Right" then
                    if ST.AutoRightOn then StopAutoMove() else StartAutoMove("AUTO_RIGHT") end
                elseif kb.name == "Mode" then
                    ST.LaggerMode = not ST.LaggerMode
                    if modeBtn then modeBtn.Text = ST.LaggerMode and "Lagger" or "Normal" end
                    if modeF then modeF.BackgroundColor3 = ST.LaggerMode and Color3.fromRGB(30,0,30) or Color3.fromRGB(12,12,12) end
                    if modeBtn then mkGlow(modeBtn, ST.LaggerMode) end
                end
            end
            return true
        end
    end
    return false
end
UIS.InputBegan:Connect(function(i, g)
    local kc = i.KeyCode
    if kc == Enum.KeyCode.W then _moveKeys.W = true end
    if kc == Enum.KeyCode.A then _moveKeys.A = true end
    if kc == Enum.KeyCode.S then _moveKeys.S = true end
    if kc == Enum.KeyCode.D then _moveKeys.D = true end
    if kc == Enum.KeyCode.Up then _moveKeys.Up = true end
    if kc == Enum.KeyCode.Down then _moveKeys.Down = true end
    if kc == Enum.KeyCode.Left then _moveKeys.Left = true end
    if kc == Enum.KeyCode.Right then _moveKeys.Right = true end
    local ut = i.UserInputType
    local isGP = (ut == Enum.UserInputType.Gamepad1 or ut == Enum.UserInputType.Gamepad2 or ut == Enum.UserInputType.Gamepad3 or ut == Enum.UserInputType.Gamepad4)
    if (ut == Enum.UserInputType.Keyboard and not g) or isGP then
        if processKeybinds(i, true) then return end
    end
    if not g then
        if kc == Enum.KeyCode.Space then ST.JumpHeld = true end
        if kc == Enum.KeyCode.ButtonA then ST.JumpHeld = true end
    end
end)
UIS.InputEnded:Connect(function(i)
    local kc = i.KeyCode
    if kc == Enum.KeyCode.W then _moveKeys.W = false end
    if kc == Enum.KeyCode.A then _moveKeys.A = false end
    if kc == Enum.KeyCode.S then _moveKeys.S = false end
    if kc == Enum.KeyCode.D then _moveKeys.D = false end
    if kc == Enum.KeyCode.Up then _moveKeys.Up = false end
    if kc == Enum.KeyCode.Down then _moveKeys.Down = false end
    if kc == Enum.KeyCode.Left then _moveKeys.Left = false end
    if kc == Enum.KeyCode.Right then _moveKeys.Right = false end
    local ut = i.UserInputType
    if ut == Enum.UserInputType.Keyboard or ut == Enum.UserInputType.Gamepad1 or ut == Enum.UserInputType.Gamepad2 or ut == Enum.UserInputType.Gamepad3 or ut == Enum.UserInputType.Gamepad4 then
        processKeybinds(i, false)
    end
    if kc == Enum.KeyCode.Space then ST.JumpHeld = false end
    if kc == Enum.KeyCode.ButtonA then ST.JumpHeld = false end
end)
local _currentJumpForce = CFG.INF_JUMP_FORCE
local _lastJumpTime = 0
local function ToggleInfJump()
    ST.InfJumpOn = not ST.InfJumpOn
    if ST.InfJumpOn then
        _currentJumpForce = CFG.INF_JUMP_FORCE
        ST.IJC = Trk(UIS.JumpRequest:Connect(function()
            if not ST.InfJumpOn then return end
            local hr = gH()
            if hr and hr.Parent then
                if CFG.INF_JUMP_SMOOTH then
                    local smoothForce = math.max(CFG.INF_JUMP_MIN_FORCE, _currentJumpForce)
                    hr.Velocity = Vector3.new((hr.Velocity and hr.Velocity.X) or 0, smoothForce, (hr.Velocity and hr.Velocity.Z) or 0)
                    _currentJumpForce = _currentJumpForce * CFG.INF_JUMP_DECAY
                    if _currentJumpForce < CFG.INF_JUMP_MIN_FORCE then
                        _currentJumpForce = CFG.INF_JUMP_FORCE
                    end
                else
                    hr.Velocity = Vector3.new((hr.Velocity and hr.Velocity.X) or 0, CFG.INF_JUMP_FORCE, (hr.Velocity and hr.Velocity.Z) or 0)
                end
            end
        end))
        ST.JHC = Trk(RunService.Heartbeat:Connect(function()
            if not ST.InfJumpOn or not ST.JumpHeld then return end
            local c = LP.Character
            if not c then return end
            local hm = c:FindFirstChildOfClass("Humanoid")
            local hr = gH()
            if hm and hr and hr.Parent and (hm:GetState() == Enum.HumanoidStateType.Freefall or hm:GetState() == Enum.HumanoidStateType.Jumping) then
                if tick() - _lastJumpTime > 0.05 then
                    _lastJumpTime = tick()
                    if CFG.INF_JUMP_SMOOTH then
                        local smoothForce = math.max(CFG.INF_JUMP_MIN_FORCE, _currentJumpForce)
                        hr.Velocity = Vector3.new((hr.Velocity and hr.Velocity.X) or 0, smoothForce, (hr.Velocity and hr.Velocity.Z) or 0)
                        _currentJumpForce = _currentJumpForce * CFG.INF_JUMP_DECAY
                        if _currentJumpForce < CFG.INF_JUMP_MIN_FORCE then
                            _currentJumpForce = CFG.INF_JUMP_FORCE
                        end
                    else
                        hr.Velocity = Vector3.new((hr.Velocity and hr.Velocity.X) or 0, CFG.INF_JUMP_FORCE, (hr.Velocity and hr.Velocity.Z) or 0)
                    end
                end
            end
        end))
    else
        if ST.IJC then ST.IJC:Disconnect(); ST.IJC = nil end
        if ST.JHC then ST.JHC:Disconnect(); ST.JHC = nil end
        ST.JumpHeld = false
        _currentJumpForce = CFG.INF_JUMP_FORCE
    end
end
safeCall("InfJump", ToggleInfJump)
local function StopSpeed()
    if ST.SpdC then ST.SpdC:Disconnect(); ST.SpdC = nil end
end
local function StartSpeed()
    if ST.SpdC then return end
    ST.SpdC = Trk(RunService.Heartbeat:Connect(function()
        if not ST.SpeedBoostOn or not _G.ExtRunning or ST.isAimbotActive or ST.AutoLeftOn or ST.AutoRightOn then return end
        if ST.DropActive then return end
        local c = LP.Character
        if not c then return end
        local hm = c:FindFirstChildOfClass("Humanoid")
        local hr = c:FindFirstChild("HumanoidRootPart")
        if not hm or not hr or not hr.Parent then return end
        local md = getKeyMoveDir()
        if md.Magnitude < 0.01 then
            md = hm.MoveDirection
            if md.Magnitude < 0.01 then return end
        end
        local tS = (iS() and gSS()) or gNS() or 0
        tS = tS or 0
        hr.Velocity = Vector3.new(md.X * tS, (hr.Velocity and hr.Velocity.Y) or 0, md.Z * tS)
    end))
    _G.ExtSpdC = ST.SpdC
end
local function ToggleSpeed()
    ST.SpeedBoostOn = not ST.SpeedBoostOn
    if ST.SpeedBoostOn then StartSpeed() else StopSpeed() end
end
safeCall("Speed", StartSpeed)
local AutoMoveThread = nil
local function SyncToggles()
    if alF then
        alF.BackgroundColor3 = ST.AutoLeftOn and Color3.fromRGB(0,30,0) or Color3.fromRGB(12,12,12)
        if alBtn then mkGlow(alBtn, ST.AutoLeftOn) end
    end
    if arF then
        arF.BackgroundColor3 = ST.AutoRightOn and Color3.fromRGB(0,30,0) or Color3.fromRGB(12,12,12)
        if arBtn then mkGlow(arBtn, ST.AutoRightOn) end
    end
end
function StopAutoMove()
    if AutoMoveThread then pcall(function() coroutine.close(AutoMoveThread) end) AutoMoveThread = nil end
    ST.AutoLeftOn = false; ST.AutoRightOn = false
    local h = gH()
    if h then pcall(function() h.Velocity = Vector3.new(0, (h.Velocity and h.Velocity.Y) or 0, 0) end) end
    SyncToggles()
end
function StartAutoMove(mode)
    StopAutoMove()
    local coords = mode == "AUTO_LEFT" and AUTO_LEFT_COORDS or AUTO_RIGHT_COORDS
    if mode == "AUTO_LEFT" then ST.AutoLeftOn = true else ST.AutoRightOn = true end
    SyncToggles()
    AutoMoveThread = coroutine.create(function()
        local pointIdx = 1
        local lastPointIdx = #coords
        local maxPointIdx = ST.AutoLeftRightFull and lastPointIdx or math.min(2, lastPointIdx)
        while _G.ExtRunning and CoreActive and (ST.AutoLeftOn or ST.AutoRightOn) do
            local h = gH()
            if not h or not h.Parent then task.wait(0.01); continue end
            if pointIdx > maxPointIdx then
                h.Velocity = Vector3.new(0, (h.Velocity and h.Velocity.Y) or 0, 0)
                StopAutoMove(); return
            end
            local tx, ty, tz = GetCoord(coords[pointIdx])
            local targetPos = Vector3.new(tx, ty, tz)
            local toTarget = targetPos - h.Position
            local xzDist = Vector3.new(toTarget.X, 0, toTarget.Z).Magnitude
            local yDist = math.abs(toTarget.Y)
            if xzDist < AUTO_MOVE_XZ_TOLERANCE and yDist < AUTO_MOVE_Y_TOLERANCE then
                if pointIdx >= maxPointIdx then
                    h.Velocity = Vector3.new(0, (h.Velocity and h.Velocity.Y) or 0, 0)
                    StopAutoMove(); return
                else
                    pointIdx = pointIdx + 1
                end
            else
                local spd = (pointIdx >= 3) and gSS() or gNS()
                local moveDir = Vector3.new(toTarget.X, 0, toTarget.Z)
                if moveDir.Magnitude > 0 then
                    h.Velocity = Vector3.new(moveDir.Unit.X * (spd or 0), (h.Velocity and h.Velocity.Y) or 0, moveDir.Unit.Z * (spd or 0))
                end
            end
            task.wait(0.01)
        end
    end)
    coroutine.resume(AutoMoveThread)
end
local _ragdollStartTime = 0
local _ragdollActive = false
local _ragdollDuration = 1.5
local function showRagdollTimer(on)
    local head = LP.Character and LP.Character:FindFirstChild("Head")
    if on and head then
        _ragdollActive = true
        _ragdollStartTime = tick()
    elseif on == "stop" then
        _ragdollActive = false
    end
end
local function EnableAR()
    for _, c in ipairs(ST.AntiRagC) do pcall(function() c:Disconnect() end) end
    ST.AntiRagC = {}
    local function CleanCon(ch)
        for _, o in pairs(ch:GetDescendants()) do
            if o:IsA("BallSocketConstraint") or o:IsA("NoCollisionConstraint") or o:IsA("HingeConstraint")
                or o:IsA("BodyVelocity") or o:IsA("BodyPosition") or o:IsA("BodyGyro") or o:IsA("AlignOrientation") then
                pcall(function() o:Destroy() end)
                elseif o:IsA("Attachment") and (o.Name == "A" or o.Name == "B") then
                    pcall(function()
                        if not o.Parent then return end
                        local parent = o.Parent
                        if parent:IsA("Tool") or parent:IsA("Accessory") then return end
                        if parent.Parent and (parent.Parent:IsA("Backpack") or parent.Parent:IsA("Tool")) then return end
                        for _, m in ipairs(parent:GetChildren()) do
                            if m:IsA("Motor6D") and (m.Part0 == parent or m.Part1 == parent) then return end
                        end
                        o:Destroy()
                    end)
                end)
            elseif o:IsA("Motor6D") then
                pcall(function() o.Enabled = true end)
            end
        end
    end
    local function ReEnCtrl()
        pcall(function()
            require(LP:WaitForChild("PlayerScripts"):WaitForChild("PlayerModule")):GetControls():Enable()
        end)
    end
    local function setupForChar(c)
        if not c then return end
        local h = c:WaitForChild("Humanoid", 5)
        local r = c:WaitForChild("HumanoidRootPart", 5)
        if not h or not r then return end
        pcall(function()
            h:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false)
            h:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
            h:SetStateEnabled(Enum.HumanoidStateType.GettingUp, false)
        end)
        local BS = {
            [Enum.HumanoidStateType.Physics] = true,
            [Enum.HumanoidStateType.Ragdoll] = true,
            [Enum.HumanoidStateType.FallingDown] = true,
            [Enum.HumanoidStateType.GettingUp] = true,
        }
        local IsRag = function() return BS[h:GetState()] == true end
        local StartRec = function()
            if ST.AntiRagRC then return end
            ST.AntiRagRC = true
            showRagdollTimer(true)
            task.spawn(function()
                while _ragdollActive do
                    local elapsed = tick() - (_ragdollStartTime or 0)
                    if elapsed >= (_ragdollDuration or 1.5) then
                        break
                    end
                    if IsRag() or h:GetState() == Enum.HumanoidStateType.GettingUp then
                        CleanCon(c)
                        pcall(function() h:ChangeState(Enum.HumanoidStateType.Running) end)
                        local v = r.Velocity or Vector3.zero
                        if v.Magnitude > 30 then
                            r.Velocity = Vector3.new(0, math.min(v.Y, 5), 0)
                        end
                        workspace.CurrentCamera.CameraSubject = h
                        ReEnCtrl()
                    else
                        break
                    end
                    pcall(function()
                        h:SetStateEnabled(Enum.HumanoidStateType.Ragdoll, false)
                        h:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
                    end)
                    task.wait(0.02)
                end
                ST.AntiRagRC = false
                showRagdollTimer("stop")
            end)
        end
        table.insert(ST.AntiRagC, h.StateChanged:Connect(function(_, nS)
            if BS[nS] then StartRec() end
        end))
        table.insert(ST.AntiRagC, RunService.Heartbeat:Connect(function()
            if not r or not r.Parent or not h or not h.Parent then return end
            if IsRag() then
                StartRec()
                local v = r.Velocity or Vector3.zero
                if (v - (ST.AntiRagLastV or Vector3.zero)).Magnitude > 50 and v.Magnitude > 20 then
                    r.Velocity = Vector3.new(0, math.min(v.Y, 5), 0)
                end
            end
            if r and r.Parent then ST.AntiRagLastV = r.Velocity or Vector3.zero end
        end))
        table.insert(ST.AntiRagC, c.DescendantAdded:Connect(function(o)
            pcall(function()
                if not o or not o.Parent then return end
                if o:IsA("BallSocketConstraint") or o:IsA("NoCollisionConstraint") or o:IsA("HingeConstraint")
                    or o:IsA("BodyVelocity") or o:IsA("BodyPosition") or o:IsA("BodyGyro") or o:IsA("AlignOrientation") then
                    task.defer(function() if o and o.Parent then o:Destroy() end end)
                elseif o:IsA("Motor6D") then
                    task.defer(function() if o and o.Parent then o.Enabled = true end end)
                end
            end)
        end))
        ReEnCtrl()
        CleanCon(c)
    end
    if LP.Character then setupForChar(LP.Character) end
    table.insert(ST.AntiRagC, LP.CharacterAdded:Connect(function(nc)
        if not ST.AntiRagOn then return end
        task.wait(1)
        setupForChar(nc)
    end))
end
safeCall("AntiRagdoll", EnableAR)
local _noclipConns = {}
local function EnableNoclip()
    ST.NoclipOn = true
    ST.NoclipC = RunService.Stepped:Connect(function()
        local c = LP.Character
        if not c then return end
        for _, part in ipairs(c:GetDescendants()) do
            if part:IsA("BasePart") and part.CanCollide then
                part.CanCollide = false
            end
        end
    end)
end
local function DisableNoclip()
    ST.NoclipOn = false
    if ST.NoclipC then ST.NoclipC:Disconnect(); ST.NoclipC = nil end
    for _, c in ipairs(_noclipConns) do
        pcall(function() c:Disconnect() end)
    end
    _noclipConns = {}
end
local function ToggleNoclip(on)
    if on then EnableNoclip() else DisableNoclip() end
end
safeCall("Noclip", EnableNoclip)
local function ToggleUnwalk(on)
    ST.UnwalkOn = on
    if on then
        local c = LP.Character
        if c then
            local hm = c:FindFirstChildOfClass("Humanoid")
            if hm then
                for _, a in ipairs(hm:GetPlayingAnimationTracks()) do
                    pcall(function() a:Stop() end)
                end
            end
        end
        ST.UnwalkC = RunService.Heartbeat:Connect(function()
            local c = LP.Character
            if not c then return end
            local hm = c:FindFirstChildOfClass("Humanoid")
            if hm then
                for _, a in ipairs(hm:GetPlayingAnimationTracks()) do
                    pcall(function() a:Stop() end)
                end
            end
        end)
    else
        if ST.UnwalkC then ST.UnwalkC:Disconnect(); ST.UnwalkC = nil end
    end
end
local _refreshing = false
local function RefreshScript()
    if _refreshing then return end
    _refreshing = true
    task.wait(0.5)
    StopSpeed()
    if ST.SpeedBoostOn then task.wait(0.05); StartSpeed() end
    local wasInfJump = ST.InfJumpOn
    if ST.IJC then ST.IJC:Disconnect(); ST.IJC = nil end
    if ST.JHC then ST.JHC:Disconnect(); ST.JHC = nil end
    ST.InfJumpOn = false; _currentJumpForce = CFG.INF_JUMP_FORCE
    if wasInfJump then
        task.wait(0.05)
        ToggleInfJump()
    end
    DisableNoclip()
    task.wait(0.1)
    EnableNoclip()
    for _, c in ipairs(ST.AntiRagC) do pcall(function() c:Disconnect() end) end
    ST.AntiRagC = {}
    if ST.AntiRagOn then
        task.wait(0.1)
        EnableAR()
    end
    if ST.isAimbotActive then
        ToggleAimbot(false)
        task.wait(0.2)
        ToggleAimbot(true)
    end
    for _, c in ipairs(ST.DropConns) do
        pcall(function() if typeof(c) == "RBXScriptConnection" then c:Disconnect() end end)
    end
    ST.DropConns = {}
    ST.DropActive = false
    _refreshing = false
end
safeCall("CharEvents", function()
LP.CharacterRemoving:Connect(function()
    task.spawn(function()
        task.wait(1)
        RefreshScript()
    end)
end)
LP.CharacterAdded:Connect(function()
    task.spawn(function()
        task.wait(1.5)
        RefreshScript()
    end)
end)
Players.PlayerRemoving:Connect(function(p)
    if p ~= LP then
        task.spawn(function()
            task.wait(0.5)
            RefreshScript()
        end)
    end
end)
end)
