local function gJP()
    return CFG.JUMP_POWER
end
local function gNS()
    if ST.LaggerMode then return CFG.LAGGER_SPEED end
    local c = LP.Character
    if not c then return CFG.SPEED_NORMAL end
    local hm = c:FindFirstChildOfClass("Humanoid")
    if hm and hm.WalkSpeed and hm.WalkSpeed > 0 then return math.max(hm.WalkSpeed, CFG.SPEED_NORMAL) end
    return CFG.SPEED_NORMAL
end
local function gSS()
    if ST.LaggerMode then return CFG.LAGGER_STEALING end
    return CFG.SPEED_STEALING
end
