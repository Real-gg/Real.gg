local _introFlashC = nil
local function StartIntroFlash()
    local flashColors = {
        Color3.fromRGB(255, 50, 50),
        Color3.fromRGB(255, 255, 255),
        Color3.fromRGB(50, 255, 50),
        Color3.fromRGB(255, 200, 50),
        Color3.fromRGB(255, 255, 255),
    }
    local colorIdx = 1
    local lastSwitch = 0
    local flashSpeed = 1 / math.max(CFG.INTRO_FLASH_SPEED or 8, 1)
    _introFlashC = RunService.Heartbeat:Connect(function()
        if not introTitle or not introTitle.Parent then return end
        local now = tick()
        if now - lastSwitch >= flashSpeed then
            lastSwitch = now
            colorIdx = (colorIdx % #flashColors) + 1
            introTitle.TextColor3 = flashColors[colorIdx]
            local discIdx = ((colorIdx + 2) % #flashColors) + 1
            introDiscord.TextColor3 = flashColors[discIdx]
        end
    end)
end
safeCall("Intro", function()
task.spawn(function()
    RunService.RenderStepped:Wait()
    local trackUrl = INTRO_TRACKS[CFG.INTRO_SELECTED_TRACK] or INTRO_TRACKS[1]
    if trackUrl then
        task.spawn(function()
            _introSound = PlayAudioFromURL(trackUrl, "RealHub_IntroAudio", 0.5, false)
        end)
    end
    StartIntroFlash()
    task.wait(0.3)
    local slideInfo = TweenInfo.new(0.8, Enum.EasingStyle.Quart, Enum.EasingDirection.Out)
    TweenService:Create(introTitle, slideInfo, {Position = UDim2.new(0.5, -300, 0.5, -100)}):Play()
    TweenService:Create(introDiscord, slideInfo, {Position = UDim2.new(0.5, 20, 0.5, 0)}):Play()
    task.wait(4)
    local fadeInfo = TweenInfo.new(1.0, Enum.EasingStyle.Quad, Enum.EasingDirection.In)
    TweenService:Create(introTitle, fadeInfo, {TextTransparency = 1, TextStrokeTransparency = 1}):Play()
    TweenService:Create(introDiscord, fadeInfo, {TextTransparency = 1, TextStrokeTransparency = 1}):Play()
    TweenService:Create(introFrame, fadeInfo, {BackgroundTransparency = 1}):Play()
    task.wait(1.2)
    if _introFlashC then _introFlashC:Disconnect(); _introFlashC = nil end
    if _introSound and _introSound.Parent then
        _introSound:Stop(); _introSound:Destroy(); _introSound = nil
    end
    StopPreviewSound()
    if introFrame and introFrame.Parent then introFrame:Destroy() end
end)
end)
