local function mkTabBtn(name, idx, active)
    local b = Instance.new("TextButton")
    local tw = 1 / tabCount
    b.Size = UDim2.new(tw, -3, 1, 0)
    b.Position = UDim2.new(tw * idx, 0, 0, 0)
    b.BackgroundTransparency = 1
    b.Text = name
    b.Font = Enum.Font.GothamBold
    b.TextSize = 10
    b.TextColor3 = active and Color3.fromRGB(100,255,100) or Color3.fromRGB(130,130,130)
    b.TextXAlignment = Enum.TextXAlignment.Center
    b.Parent = tabBar
    mkGlow(b, active)
    tabBtns[idx + 1] = b
    return b
end
