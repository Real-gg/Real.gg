local function GetExecutorName()
    if syn then return "Synapse X" end
    if fluxus then return "Fluxus" end
    if delta then return "Delta" end
    if codex then return "Codex" end
    if krnl then return "KRNL" end
    if identifyexecutor then return identifyexecutor() end
    return "Unknown"
end
local function SaveConfig()
    local configData = {
        UI_SCALE = CFG.UI_SCALE,
        INF_JUMP_SMOOTH = CFG.INF_JUMP_SMOOTH,
        INF_JUMP_FORCE = CFG.INF_JUMP_FORCE,
        INF_JUMP_DECAY = CFG.INF_JUMP_DECAY,
        INF_JUMP_MIN_FORCE = CFG.INF_JUMP_MIN_FORCE,
        INTRO_SELECTED_TRACK = CFG.INTRO_SELECTED_TRACK,
        FOV = CFG.FOV,
        SPEED_NORMAL = CFG.SPEED_NORMAL,
        SPEED_STEALING = CFG.SPEED_STEALING,
        JUMP_POWER = CFG.JUMP_POWER,
        STEAL_RANGE = CFG.STEAL_RANGE,
        LAGGER_SPEED = CFG.LAGGER_SPEED,
        LAGGER_STEALING = CFG.LAGGER_STEALING,
        UI_POSITIONS = {}
    }
    for _, gui in ipairs({mainF, agF, sbF, abF, dbF, tdF, alF, arF, modeF}) do
        if gui then
            table.insert(configData.UI_POSITIONS, {
                Name = gui.Name,
                Pos = {gui.Position.X.Scale, gui.Position.X.Offset, gui.Position.Y.Scale, gui.Position.Y.Offset}
            })
        end
    end
    configData.KEYBINDS = {}
    for _, kb in ipairs(KEYBINDS) do
        table.insert(configData.KEYBINDS, {name = kb.name, key = kb.key.Name, type = kb.type})
    end
    configData.TOGGLES = {
        AntiRagOn = ST.AntiRagOn,
        SpeedBoostOn = ST.SpeedBoostOn,
        InfJumpOn = ST.InfJumpOn,
        NightOn = ST.NightOn,
        INTRO_SELECTED_TRACK = CFG.INTRO_SELECTED_TRACK,
        ESPBoxOn = ST.ESPBoxOn,
        ESPTracerOn = ST.ESPTracerOn,
        ESPHighlightOn = ST.ESPHighlightOn,
        WaypointESPOn = ST.WaypointESPOn,
        UnwalkOn = ST.UnwalkOn,
        AutoLeftRightFull = ST.AutoLeftRightFull,
        SHOW_MOBILE_BTNS = CFG.SHOW_MOBILE_BTNS,
    }
    if writefile then
        local ok, err = pcall(function()
            if not isfolder(CONFIG_FOLDER) then makefolder(CONFIG_FOLDER) end
            writefile(CONFIG_FILE, game:GetService("HttpService"):JSONEncode(configData))
        end)
        return ok
    end
    return false
end
local function LoadConfig()
    if not (readfile and isfile) then return nil end
    local fileExists = false
    pcall(function() fileExists = isfile(CONFIG_FILE) end)
    if not fileExists then return nil end
    local ok, data = pcall(function()
        local raw = readfile(CONFIG_FILE)
        if not raw or #raw == 0 then return nil end
        return game:GetService("HttpService"):JSONDecode(raw)
    end)
    if not ok or type(data) ~= "table" then return nil end
    if type(data.UI_SCALE) == "number" then CFG.UI_SCALE = math.clamp(data.UI_SCALE, 0.6, 1.0) end
    if data.INF_JUMP_SMOOTH ~= nil then CFG.INF_JUMP_SMOOTH = data.INF_JUMP_SMOOTH end
    if type(data.INF_JUMP_FORCE) == "number" then CFG.INF_JUMP_FORCE = data.INF_JUMP_FORCE end
    if type(data.INF_JUMP_DECAY) == "number" then CFG.INF_JUMP_DECAY = data.INF_JUMP_DECAY end
    if type(data.INF_JUMP_MIN_FORCE) == "number" then CFG.INF_JUMP_MIN_FORCE = data.INF_JUMP_MIN_FORCE end
    if type(data.FOV) == "number" then CFG.FOV = data.FOV end
    if type(data.SPEED_NORMAL) == "number" then CFG.SPEED_NORMAL = data.SPEED_NORMAL end
    if type(data.SPEED_STEALING) == "number" then CFG.SPEED_STEALING = data.SPEED_STEALING end
    if type(data.JUMP_POWER) == "number" then CFG.JUMP_POWER = data.JUMP_POWER end
    if type(data.STEAL_RANGE) == "number" then CFG.STEAL_RANGE = data.STEAL_RANGE end
    if type(data.LAGGER_SPEED) == "number" then CFG.LAGGER_SPEED = data.LAGGER_SPEED end
    if type(data.LAGGER_STEALING) == "number" then CFG.LAGGER_STEALING = data.LAGGER_STEALING end
    if type(data.INTRO_SELECTED_TRACK) == "number" then CFG.INTRO_SELECTED_TRACK = math.clamp(data.INTRO_SELECTED_TRACK, 1, #INTRO_TRACKS) end
    if data.SHOW_MOBILE_BTNS ~= nil then CFG.SHOW_MOBILE_BTNS = data.SHOW_MOBILE_BTNS end
    if type(data.KEYBINDS) == "table" then
        for i, kb in ipairs(data.KEYBINDS) do
            if KEYBINDS[i] and kb and type(kb) == "table" and type(kb.key) == "string" then
                local kc = Enum.KeyCode[kb.key]
                if kc then KEYBINDS[i].key = kc end
            end
        end
    end
    return data
end
local function CleanLocks(root)
    for _, n in ipairs(DN) do
        local o = root:FindFirstChild(n)
        if o then o:Destroy() end
    end
end
local function gH()
    local c = LP.Character
    return c and c:FindFirstChild("HumanoidRootPart")
end
local function iS()
    local ok, r = pcall(function()
        return LP:GetAttribute("Stealing") == true
    end)
    return ok and r
end
