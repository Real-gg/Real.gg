local _activeDrags = {}
local function MakeDraggable(handle, frame)
    frame = frame or handle
    handle.Active = true
    handle.InputBegan:Connect(function(input)
        local ut = input.UserInputType
        if ut ~= Enum.UserInputType.MouseButton1 and ut ~= Enum.UserInputType.Touch then return end
        local tweenObj = nil
        _activeDrags[input] = {
            frame = frame,
            startPos = frame.Position,
            startInput = input.Position,
            tweenObj = nil,
        }
    end)
    handle.InputChanged:Connect(function(input)
        local drag = _activeDrags[input]
        if not drag then return end
        if input.UserInputType ~= Enum.UserInputType.MouseMovement and input.UserInputType ~= Enum.UserInputType.Touch then return end
        local delta = input.Position - drag.startInput
        local viewportSize = workspace.CurrentCamera.ViewportSize
        local scale = uiScaleObj and uiScaleObj.Scale or 1
        local newX = drag.startPos.X.Offset + delta.X
        local newY = drag.startPos.Y.Offset + delta.Y
        local fw = drag.frame.AbsoluteSize.X / scale
        local fh = drag.frame.AbsoluteSize.Y / scale
        local sw = viewportSize.X / scale
        local sh = viewportSize.Y / scale
        newX = math.clamp(newX, -fw + 20, sw - 20)
        newY = math.clamp(newY, 0, sh - fh)
        local targetPos = UDim2.new(
            drag.startPos.X.Scale, newX,
            drag.startPos.Y.Scale, newY
        )
        if drag.tweenObj then drag.tweenObj:Cancel() end
        drag.tweenObj = TweenService:Create(
            drag.frame,
            TweenInfo.new(0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
            {Position = targetPos}
        )
        drag.tweenObj:Play()
    end)
end
UIS.InputEnded:Connect(function(input)
    if _activeDrags[input] then
        local drag = _activeDrags[input]
        if drag and drag.tweenObj then drag.tweenObj:Cancel() end
        _activeDrags[input] = nil
    end
end)
