local _bloomEffect = nil
local _origLighting = {}
local _darknessVal = 0
local _neonGlowVal = 1.0
local function ApplyNightValues()
    local d = _darknessVal
    Lighting.Brightness = 0
    Lighting.Ambient = Color3.fromRGB(math.floor(30 * (1 - d)), math.floor(30 * (1 - d)), math.floor(30 * (1 - d)))
    Lighting.OutdoorAmbient = Color3.fromRGB(math.floor(20 * (1 - d)), math.floor(20 * (1 - d)), math.floor(20 * (1 - d)))
    Lighting.ClockTime = 0
    Lighting.FogEnd = math.floor(1000 - d * 700)
end
local function ToggleNight(on)
    ST.NightOn = on
    if on then
        _origLighting.Brightness = Lighting.Brightness
        _origLighting.Ambient = Lighting.Ambient
        _origLighting.OutdoorAmbient = Lighting.OutdoorAmbient
        _origLighting.ClockTime = Lighting.ClockTime
        _origLighting.FogEnd = Lighting.FogEnd
        ApplyNightValues()
        if not _bloomEffect then
            _bloomEffect = Instance.new("BloomEffect")
            _bloomEffect.Name = "RealHub_Bloom"
            _bloomEffect.Intensity = _neonGlowVal
            _bloomEffect.Size = 24
            _bloomEffect.Threshold = 0.8
            _bloomEffect.Parent = Lighting
        end
        _bloomEffect.Enabled = true
        _bloomEffect.Intensity = _neonGlowVal
    else
        if _origLighting.Brightness ~= nil then
            Lighting.Brightness = _origLighting.Brightness
            Lighting.Ambient = _origLighting.Ambient
            Lighting.OutdoorAmbient = _origLighting.OutdoorAmbient
            Lighting.ClockTime = _origLighting.ClockTime
            Lighting.FogEnd = _origLighting.FogEnd
        end
        if _bloomEffect then _bloomEffect.Enabled = false end
    end
end
safeCall("Night", function() task.defer(function() ToggleNight(true) end) end)
