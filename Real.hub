local fps = 0
local lastT = tick()
local function getPing()
    local ok, r = pcall(function()
        return Stats.Network.ServerStatsItem["Data Ping"]:GetValueString()
    end)
    return ok and tostring(r) or "0"
end
local _glowAnims = {}
local ES = 50
local cam = workspace.CurrentCamera
mkGlow = function(lbl, on)
    if not lbl or not lbl.Parent then return end
    local ex = lbl:FindFirstChild("AG")
    if ex then ex:Destroy() end
    lbl.TextColor3 = Color3.fromRGB(255,255,255)
    lbl.Font = Enum.Font.GothamBlack
    lbl.TextStrokeTransparency = 0
    lbl.TextStrokeColor3 = Color3.fromRGB(0,0,0)
    local g = Instance.new("UIGradient")
    g.Name = "AG"
    local oc = Color3.fromRGB(30,0,0)
    local ac = Color3.fromRGB(0,50,0)
    local og = Color3.fromRGB(255,50,50)
    local ag = Color3.fromRGB(50,255,50)
    if on then
        g.Color = ColorSequence.new{
            ColorSequenceKeypoint.new(0, ac),
            ColorSequenceKeypoint.new(0.5, ag),
            ColorSequenceKeypoint.new(1, ac)
        }
    else
        g.Color = ColorSequence.new{
            ColorSequenceKeypoint.new(0, oc),
            ColorSequenceKeypoint.new(0.5, og),
            ColorSequenceKeypoint.new(1, oc)
        }
    end
    g.Rotation = 0
    g.Parent = lbl
    table.insert(_glowAnims, {g = g, sp = ES + math.random(-20,20), rt = math.random(0,360)})
end
local _outlineAnims = {}
mkOutline = function(ui, th)
    th = th or 1.5
    if not ui or ui:FindFirstChild("RS") then return end
    local s = Instance.new("UIStroke")
    s.Name = "RS"
    s.Thickness = th
    s.Transparency = 0
    s.Color = Color3.fromRGB(255,50,50)
    s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    s.Parent = ui
    local g = Instance.new("UIGradient")
    g.Name = "RSG"
    g.Color = ColorSequence.new{
        ColorSequenceKeypoint.new(0, Color3.fromRGB(0,0,0)),
        ColorSequenceKeypoint.new(0.2, Color3.fromRGB(50,0,0)),
        ColorSequenceKeypoint.new(0.5, Color3.fromRGB(255,50,50)),
        ColorSequenceKeypoint.new(0.8, Color3.fromRGB(50,0,0)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(0,0,0))
    }
    g.Rotation = 0
    g.Parent = s
    table.insert(_outlineAnims, {s = s, g = g, th = th, r = 0})
end
RunService.Heartbeat:Connect(function(dt)
    local n = tick()
    local d = n - (lastT or tick())
    lastT = n
    if d and d > 0 then fps = math.floor(1/d) or 0 end
    _curFOV = (_curFOV or 70) + (math.clamp(CFG.FOV, 1, 120) - (_curFOV or 70)) * (1 - math.exp(-4 * (dt or 0)))
    cam.FieldOfView = _curFOV
    for i = #_glowAnims, 1, -1 do
        local a = _glowAnims[i]
        if not a.g or not a.g.Parent then table.remove(_glowAnims, i)
        else a.rt = (a.rt + a.sp * dt) % 360; a.g.Rotation = a.rt end
    end
    local now = tick()
    for i = #_outlineAnims, 1, -1 do
        local a = _outlineAnims[i]
        if not a.s or not a.s.Parent then table.remove(_outlineAnims, i)
        else a.r = (a.r + 50 * dt) % 360; a.g.Rotation = a.r; a.s.Thickness = a.th + ((math.sin(now * 2) + 1) / 2) * 2 end
    end
end)
